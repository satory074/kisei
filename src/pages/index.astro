---
import "../styles/globals.css";
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <title>帰省 — 経路くらべ</title>
    <meta
      name="description"
      content="飛行機・新幹線・フェリー・車を組み合わせた経路の所要時間と料金を一覧比較する"
    />
  </head>
  <body>
    <main id="app">
      <noscript>このアプリの利用には JavaScript が必要です。</noscript>
    </main>
    <script>
      import { boot } from "../app/main";
      boot(document.getElementById("app")!);
    </script>
  </body>
</html>
